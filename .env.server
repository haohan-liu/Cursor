# =====================================================
# 后端环境配置文件 (.env.server)
# =====================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改 CORS_ORIGIN 为允许访问的域名
# =====================================================

# ==================== 服务器配置 ====================
# 服务器端口
PORT=3000

# 运行环境
NODE_ENV=development

# ==================== 数据库配置 ====================
# 数据库文件路径
DB_PATH=./inventory.db

# ==================== CORS 配置 ====================
# 【重要】允许的跨域来源，多个用逗号分隔
# 开发环境示例（本地前端）
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 生产环境请替换为你的实际域名，例如：
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# 如果有其他前端域名需要访问，也需要添加：
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-domain.com
