# =====================================================
# 生产环境配置文件 (.env.production)
# =====================================================
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 修改下方的 VITE_API_BASE_URL 为你的线上后端 API 地址
# 3. 确保域名已添加到后端的 CORS 白名单
# =====================================================

# ==================== 前端配置 ====================
# 【重要】线上后端 API 地址 - 修改这里！
VITE_API_BASE_URL=https://api.hc00.cn/api

# API 请求超时时间（毫秒），可选，默认 10000
VITE_API_TIMEOUT=15000

# ==================== 后端配置（可选）====================
# 如果你也想在此配置后端参数
# PORT=3000
# NODE_ENV=production
# DB_PATH=./inventory.db
# 允许的跨域来源，多个用逗号分隔
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
