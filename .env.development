# =====================================================
# 开发环境配置文件 (.env.development)
# =====================================================
# 使用说明：
# 1. 复制此文件为 .env.development
# 2. 修改下方的 VITE_API_BASE_URL 为你的后端 API 地址
# 3. 不需要修改的文件可以删除或留空
# =====================================================

# ==================== 前端配置 ====================
# 【重要】后端 API 地址 - 修改这里！
# 方式1: 本地开发连接后端服务
VITE_API_BASE_URL=http://localhost:3000/api

# 方式2: 如果后端部署在局域网其他机器
# VITE_API_BASE_URL=http://192.168.1.100:3000/api

# API 请求超时时间（毫秒），可选，默认 10000
VITE_API_TIMEOUT=10000

# ==================== 后端配置（可选）====================
# 如果你也想在此配置后端参数
# PORT=3000
# NODE_ENV=development
# DB_PATH=./inventory.db
